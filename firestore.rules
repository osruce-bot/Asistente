rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated (including anonymous).
    function isSignedIn() {
      return request.auth != null;
    }

    match /config_general/{configId} {
      allow read, write: if isSignedIn();
    }

    match /asistentes/{asistenteId} {
      allow read, write: if isSignedIn();
    }

    match /citas/{citaId} {
      allow read, write: if isSignedIn();
    }

    match /liquidaciones/{liquidacionId} {
      allow read, write: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
